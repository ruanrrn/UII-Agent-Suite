HOST=0.0.0.0
PORT=8970
MCP_PATH=/mcp
MCP_API_KEY=replace-with-a-long-random-key
MCP_SESSION_MODE=stateful
MCP_ENABLE_JSON_RESPONSE=false
MCP_BODY_LIMIT_BYTES=1048576
MCP_SESSION_IDLE_MS=1800000
MCP_SESSION_SWEEP_MS=60000

# Optional hardening for intranet publishing.
# MCP_ALLOWED_HOSTS=10.5.178.21:8970,127.0.0.1:8970
# MCP_ALLOWED_ORIGINS=
# MCP_CORS_ALLOW_ORIGIN=

AI_TASK_API_BASE=http://10.9.54.49:30979/api/common
AI_TASK_POLL_INTERVAL_MS=5000
AI_TASK_TIMEOUT_MS=600000
AI_TASK_REQUEST_TIMEOUT_MS=30000

# Server-side bounded long-poll for get_imaging_task.
# MAX_WAIT_MS caps how long a single query call may block server-side.
# DEFAULT_WAIT_MS applies when the caller omits waitSeconds (0 = single check).
AI_TASK_MAX_WAIT_MS=120000
AI_TASK_DEFAULT_WAIT_MS=0
